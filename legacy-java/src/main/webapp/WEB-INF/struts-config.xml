<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts-config PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
        "http://struts.apache.org/dtds/struts-config_1_3.dtd">

<struts-config>

    <form-beans>
        <form-bean name="newOrderForm" type="com.orderco.legacy.form.NewOrderForm"/>
        <form-bean name="lineItemForm" type="com.orderco.legacy.form.LineItemForm"/>
    </form-beans>

    <action-mappings>

        <action path="/orders" type="com.orderco.legacy.action.ListOrdersAction">
            <forward name="success" path="/orders/list.jsp"/>
        </action>

        <action path="/newOrder" type="com.orderco.legacy.action.ShowNewOrderFormAction">
            <forward name="success" path="/orders/new.jsp"/>
        </action>

        <action path="/createOrder" type="com.orderco.legacy.action.CreateOrderAction"
                name="newOrderForm" scope="request" validate="false">
            <forward name="success" path="/viewOrder.do"/>
        </action>

        <action path="/viewOrder" type="com.orderco.legacy.action.ViewOrderAction">
            <forward name="success" path="/orders/view.jsp"/>
            <forward name="notfound" path="/orders/notfound.jsp"/>
        </action>

        <action path="/addLineItem" type="com.orderco.legacy.action.AddLineItemAction"
                name="lineItemForm" scope="request" validate="false">
            <forward name="success" path="/viewOrder.do"/>
            <forward name="error" path="/orders/view.jsp"/>
        </action>

        <action path="/submitOrder" type="com.orderco.legacy.action.SubmitOrderAction">
            <forward name="success" path="/viewOrder.do"/>
            <forward name="error" path="/orders/view.jsp"/>
        </action>

        <action path="/approveOrder" type="com.orderco.legacy.action.ApproveOrderAction">
            <forward name="success" path="/viewOrder.do"/>
            <forward name="error" path="/orders/view.jsp"/>
        </action>

        <action path="/rejectOrder" type="com.orderco.legacy.action.RejectOrderAction">
            <forward name="success" path="/viewOrder.do"/>
            <forward name="error" path="/orders/view.jsp"/>
        </action>

    </action-mappings>

</struts-config>
